---
const navLinks = [
  { href: "#features", label: "Características" },
  { href: "#how-it-works", label: "¿Cómo funciona?" },
  { href: "#testimonials", label: "Testimonios" },
  { href: "#contact", label: "Contacto" },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-2.5 group">
        <div
          class="w-9 h-9 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
          style="background: var(--gradient-brand); box-shadow: var(--glow-blue);"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            style="color: var(--bg-base);"
          >
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"></path>
          </svg>
        </div>

        <span class="text-xl font-extrabold tracking-tight">
          <span class="text-white">Habita</span><span class="text-blue-400"
            >red</span
          >
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="hover:text-white transition-colors text-sm font-medium px-4 py-2 rounded-lg hover:bg-[#0f1535]"
              style="color: var(--text-secondary);"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden lg:flex items-center gap-3">
        <a
          href="#"
          class="text-sm font-medium px-4 py-2.5 rounded-xl border transition-all hover:text-white hover:border-[rgba(15,98,254,0.4)] hover:bg-[#0f1535]"
          style="color: var(--text-secondary); border-color: var(--border-base);"
        >
          Iniciar sesión
        </a>
        <a
          href="#contact"
          class="text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-all hover:scale-105 hover:opacity-90"
          style="background: var(--gradient-brand); box-shadow: var(--glow-blue);"
        >
          Solicitar Demo →
        </a>
      </div>

      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 hover:text-white rounded-lg hover:bg-[#0f1535] transition-colors"
        style="color: var(--text-secondary);"
        aria-label="Abrir menú"
      >
        <svg
          id="icon-open"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="icon-close"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden lg:hidden backdrop-blur-sm border-t"
    style="background: rgba(10, 15, 46, 0.98); border-color: var(--border-dim);"
  >
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="hover:text-white py-3 px-3 font-medium rounded-lg hover:bg-[#0f1535] transition-colors"
            style="color: var(--text-secondary);"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#"
        class="font-medium text-center py-3 rounded-xl border transition-all hover:text-white hover:border-[rgba(15,98,254,0.4)] hover:bg-[#0f1535] mt-3"
        style="color: var(--text-secondary); border-color: var(--border-base);"
      >
        Iniciar sesión
      </a>
      <a
        href="#contact"
        class="text-white font-bold text-center py-3.5 rounded-xl transition-all hover:opacity-90 mt-2"
        style="background: var(--gradient-brand); box-shadow: var(--glow-blue);"
      >
        Solicitar Demo Gratuita →
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("header");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.style.setProperty("background", "rgba(6, 9, 26, 0.95)");
      header?.style.setProperty("backdrop-filter", "blur(12px)");
      header?.style.setProperty("-webkit-backdrop-filter", "blur(12px)");
      header?.style.setProperty(
        "border-bottom",
        "1px solid rgba(15, 98, 254, 0.12)",
      );
      header?.style.setProperty(
        "box-shadow",
        "0 20px 40px rgba(6, 9, 26, 0.6)",
      );
    } else {
      header?.style.removeProperty("background");
      header?.style.removeProperty("backdrop-filter");
      header?.style.removeProperty("-webkit-backdrop-filter");
      header?.style.removeProperty("border-bottom");
      header?.style.removeProperty("box-shadow");
    }
  });

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
