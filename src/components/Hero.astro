---
const today = new Date().toLocaleDateString("es-CO", {
  weekday: "long",
  day: "numeric",
  month: "long",
});
const todayCapitalized = today.charAt(0).toUpperCase() + today.slice(1);

const avatars = [
  { initial: "M", color: "bg-amber-400" },
  { initial: "C", color: "bg-indigo-400" },
  { initial: "A", color: "bg-emerald-400" },
  { initial: "J", color: "bg-rose-400" },
];
---

<section
  class="relative min-h-screen flex items-center overflow-hidden pt-16 sm:pt-20"
  style="background: var(--bg-base);"
>
  <div
    class="absolute inset-0 overflow-hidden pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute -top-40 -right-40 w-125 h-125 rounded-full blur-3xl animate-pulse"
      style="background: rgba(15, 98, 254, 0.07);"
    >
    </div>
    <div
      class="absolute top-1/3 -left-40 w-100 h-100 rounded-full blur-3xl animate-pulse"
      style="background: rgba(14, 165, 233, 0.06); animation-delay:1.5s;"
    >
    </div>
    <div
      class="absolute bottom-0 right-1/3 w-75 h-75 rounded-full blur-3xl"
      style="background: rgba(129, 140, 248, 0.04);"
    >
    </div>
  </div>

  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12 w-full"
  >
    <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">
      <div class="text-center lg:text-left">
        <div
          class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-7"
          style="background: rgba(15, 98, 254, 0.1); border: 1px solid rgba(15, 98, 254, 0.25);"
        >
          <span
            class="w-2 h-2 rounded-full animate-pulse"
            style="background: var(--brand-cyan);"></span>
          <span
            class="text-sm font-semibold tracking-wide"
            style="color: var(--brand-cyan);"
            >Software de administración para conjuntos residenciales</span
          >
        </div>

        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.08] tracking-tight mb-6"
        >
          El sistema <span
            style="background: var(--gradient-brand); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >inteligente</span
          > para administrar su conjunto.
        </h1>

        <p
          class="text-lg sm:text-xl leading-relaxed mb-10 max-w-lg mx-auto lg:mx-0"
          style="color: var(--text-secondary);"
        >
          Unifica <strong style="color: var(--text-primary); font-weight: 500;"
            >residentes, visitantes, vehículos, reservas y seguridad</strong
          > en una sola plataforma. Diseñada para administradores que exigen resultados
          reales.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-12"
        >
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 text-white font-bold text-base px-8 py-4 rounded-xl transition-all hover:scale-105 hover:opacity-90"
            style="background: var(--gradient-brand); box-shadow: var(--glow-blue);"
          >
            Agenda tu demo gratis
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="#features"
            class="inline-flex items-center justify-center gap-2 font-semibold text-base px-8 py-4 rounded-xl transition-all hover:text-white"
            style="border: 1px solid var(--border-base); color: var(--text-secondary); hover:background: var(--bg-layer2);"
            onmouseover="this.style.borderColor='var(--border-bright)'; this.style.background='var(--bg-layer2)';"
            onmouseout="this.style.borderColor='var(--border-base)'; this.style.background='transparent';"
          >
            Ver características
          </a>
        </div>

        <div class="flex items-center gap-4 justify-center lg:justify-start">
          <div class="flex -space-x-2.5">
            {
              avatars.map((a) => (
                <div
                  class={`w-9 h-9 rounded-full border-2 flex items-center justify-center text-xs font-bold text-slate-950 ${a.color}`}
                  style="border-color: var(--bg-base);"
                >
                  {a.initial}
                </div>
              ))
            }
          </div>
          <p class="text-sm" style="color: var(--text-secondary);">
            <span style="color: var(--text-primary); font-weight: 600;"
              >+200 conjuntos</span
            > confían su administración a Habitared
          </p>
        </div>
      </div>

      <div class="relative">
        <div
          class="absolute inset-0 rounded-3xl blur-2xl scale-105"
          style="background: rgba(15, 98, 254, 0.05);"
          aria-hidden="true"
        >
        </div>

        <div
          class="relative backdrop-blur-sm rounded-2xl p-5"
          style="background: var(--glass-bg); border: 1px solid var(--glass-border); box-shadow: var(--shadow-lg);"
        >
          <div
            class="flex items-center gap-2 mb-4 pb-4"
            style="border-bottom: 1px solid var(--border-dim);"
          >
            <div class="w-3 h-3 rounded-full bg-rose-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-amber-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-500/70"></div>
            <div
              class="flex-1 rounded-full h-5 mx-2 flex items-center px-3"
              style="background: rgba(15, 23, 42, 0.6);"
            >
              <span class="text-xs font-mono" style="color: var(--text-muted);"
                >app.habitared.tech/dashboard</span
              >
            </div>
          </div>

          <div class="flex items-center justify-between mb-5">
            <div>
              <p class="text-white font-semibold text-sm">
                Buenos días, Iván ☀️
              </p>
              <p class="text-xs mt-0.5" style="color: var(--text-muted);">
                Conjunto Los Pinos · {todayCapitalized}
              </p>
            </div>
            <div
              class="w-9 h-9 rounded-full flex items-center justify-center text-white font-bold text-sm"
              style="background: var(--gradient-brand);"
            >
              I
            </div>
          </div>

          <div class="grid grid-cols-3 gap-2.5 mb-4">
            <div
              class="rounded-xl p-3 text-center"
              style="background: rgba(15, 98, 254, 0.08); border: 1px solid var(--border-dim);"
            >
              <p
                class="font-bold text-xl leading-none mb-0.5"
                style="color: var(--brand-cyan);"
              >
                24
              </p>
              <p
                class="text-xs leading-tight"
                style="color: var(--text-secondary);"
              >
                Vehículos
              </p>
              <p class="text-[10px]" style="color: var(--text-muted);">
                de 30 activos
              </p>
            </div>
            <div
              class="rounded-xl p-3 text-center"
              style="background: rgba(52, 211, 153, 0.07); border: 1px solid var(--border-dim);"
            >
              <p
                class="font-bold text-xl leading-none mb-0.5"
                style="color: var(--brand-green);"
              >
                8
              </p>
              <p
                class="text-xs leading-tight"
                style="color: var(--text-secondary);"
              >
                En el Gym
              </p>
              <p class="text-[10px]" style="color: var(--text-muted);">
                3 cupos libres
              </p>
            </div>
            <div
              class="rounded-xl p-3 text-center"
              style="background: rgba(129, 140, 248, 0.07); border: 1px solid var(--border-dim);"
            >
              <p
                class="font-bold text-xl leading-none mb-0.5"
                style="color: var(--brand-purple);"
              >
                3
              </p>
              <p
                class="text-xs leading-tight"
                style="color: var(--text-secondary);"
              >
                Reservas
              </p>
              <p class="text-[10px]" style="color: var(--text-muted);">
                confirmadas hoy
              </p>
            </div>
          </div>

          <div
            class="rounded-xl p-3.5 mb-3"
            style="background: rgba(15, 23, 42, 0.5); border: 1px solid var(--border-dim);"
          >
            <p
              class="text-xs font-semibold uppercase tracking-wide mb-3"
              style="color: var(--text-muted);"
            >
              Actividad reciente
            </p>
            <div class="space-y-2.5">
              <div class="flex items-center gap-2.5">
                <div
                  class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-sm"
                  style="background: rgba(15, 98, 254, 0.15);"
                >
                  🚗
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-white text-xs font-medium">
                    ABC-123 · Vehículo residente
                  </p>
                  <p class="text-[11px]" style="color: var(--text-muted);">
                    Hace 2 min · Portería Norte
                  </p>
                </div>
                <span
                  class="text-[11px] bg-emerald-400/15 text-emerald-400 px-2 py-0.5 rounded-full font-medium shrink-0"
                  >Ingresó</span
                >
              </div>
              <div class="flex items-center gap-2.5">
                <div
                  class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-sm"
                  style="background: rgba(129, 140, 248, 0.15);"
                >
                  🏋️
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-white text-xs font-medium">
                    Juan P. · Acceso gimnasio
                  </p>
                  <p class="text-[11px]" style="color: var(--text-muted);">
                    Hace 15 min
                  </p>
                </div>
                <span
                  class="text-[11px] bg-rose-400/15 text-rose-400 px-2 py-0.5 rounded-full font-medium shrink-0"
                  >Salió</span
                >
              </div>
              <div class="flex items-center gap-2.5">
                <div
                  class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-sm"
                  style="background: rgba(14, 165, 233, 0.15);"
                >
                  📞
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-white text-xs font-medium">
                    Visita autorizada · Apto 204
                  </p>
                  <p class="text-[11px]" style="color: var(--text-muted);">
                    Hace 22 min · Citofonía digital
                  </p>
                </div>
                <span
                  class="text-[11px] bg-violet-400/15 text-violet-400 px-2 py-0.5 rounded-full font-medium shrink-0"
                  >OK</span
                >
              </div>
            </div>
          </div>

          <div
            class="rounded-xl p-3.5 flex items-center gap-3"
            style="background: linear-gradient(to right, rgba(15, 98, 254, 0.08), transparent); border: 1px solid rgba(15, 98, 254, 0.2);"
          >
            <span class="text-2xl">📷</span>
            <div class="flex-1">
              <p class="text-white text-xs font-semibold">
                Reconocimiento de placas activo
              </p>
              <p class="text-[11px]" style="color: var(--text-secondary);">
                IA · Portería Norte y Sur
              </p>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"
              ></span>
              <span class="text-emerald-400 text-xs font-medium">Online</span>
            </div>
          </div>
        </div>

        <div
          class="absolute -top-5 -right-5 rounded-2xl p-3 animate-bounce hidden lg:flex items-center gap-3"
          style="background: var(--glass-bg); border: 1px solid var(--glass-border); box-shadow: var(--shadow-md); backdrop-filter: blur(12px);"
        >
          <div
            class="w-9 h-9 bg-emerald-400/15 rounded-xl flex items-center justify-center text-lg shrink-0"
          >
            ✅
          </div>
          <div>
            <p class="text-white text-xs font-semibold">Reserva confirmada</p>
            <p class="text-[11px]" style="color: var(--text-secondary);">
              Salón comunal · Sáb. 10:00 am
            </p>
          </div>
        </div>

        <div
          class="absolute -bottom-5 -left-5 rounded-2xl p-3 animate-bounce hidden lg:flex items-center gap-3"
          style="background: var(--glass-bg); border: 1px solid var(--glass-border); box-shadow: var(--shadow-md); backdrop-filter: blur(12px); animation-delay: 1s;"
        >
          <div
            class="w-9 h-9 bg-amber-400/15 rounded-xl flex items-center justify-center text-lg shrink-0"
          >
            💰
          </div>
          <div>
            <p class="text-white text-xs font-semibold">
              Cuota de administración
            </p>
            <p class="text-[11px]" style="color: var(--text-secondary);">
              Apto 302 · $180.000 pagado
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 animate-bounce"
    style="color: var(--text-muted);"
    aria-hidden="true"
  >
    <span class="text-xs tracking-wide">Explora la plataforma</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"></path>
    </svg>
  </div>
</section>
