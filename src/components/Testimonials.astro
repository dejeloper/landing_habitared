---
const testimonials = [
  {
    quote:
      "Antes manejábamos los parqueaderos con planillas en Excel y teníamos problemas todos los días. Con Habitared, la lectura automática de placas eliminó el 90% de los conflictos. Los residentes están mucho más satisfechos.",
    name: "María González",
    role: "Administradora",
    conjunto: "Conjunto Residencial Los Pinos · Bogotá",
    initial: "M",
    color: "bg-blue-400",
    rating: 5,
  },
  {
    quote:
      "La integración del gym, la piscina y las reservas en una sola app fue un cambio total. Ahora el portero ya no tiene que llamarme para saber quién puede entrar. Todo está automatizado y queda registrado.",
    name: "Carlos Ramírez",
    role: "Gerente de Copropiedad",
    conjunto: "Torres del Norte · Medellín",
    initial: "C",
    color: "bg-indigo-400",
    rating: 5,
  },
  {
    quote:
      "Los cobros automáticos y la gestión de cartera nos ahorraron horas de trabajo cada mes. Ahora tenemos claridad total del estado financiero del conjunto y los residentes reciben sus recibos al instante.",
    name: "Ana Salcedo",
    role: "Administradora",
    conjunto: "Reservas del Parque · Cali",
    initial: "A",
    color: "bg-emerald-400",
    rating: 5,
  },
];
---

<section
  id="testimonios"
  class="relative bg-slate-950 py-24 lg:py-32 overflow-hidden"
>
  <div
    class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-slate-700 to-transparent cursor-default"
    aria-hidden="true"
  >
  </div>

  <div
    class="absolute bottom-0 right-0 w-100 h-75 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none cursor-default"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 cursor-default">
    <div class="text-center mb-14 lg:mb-18">
      <div
        class="inline-flex items-center gap-2 bg-slate-800 border border-slate-700 rounded-full px-4 py-1.5 mb-5"
      >
        <span class="text-blue-400">★★★★★</span>
        <span class="text-slate-400 text-sm"
          >4.9/5 · más de 200 copropiedades</span
        >
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-5 tracking-tight"
      >
        Lo que dicen nuestros<br class="hidden sm:block" /> administradores
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        Copropiedades reales, resultados reales. Así es como Habitared
        transforma la administración día a día.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-6 lg:gap-8">
      {
        testimonials.map((t) => (
          <div class="relative bg-slate-900/60 border border-slate-800 rounded-2xl p-7 hover:border-slate-700 hover:bg-slate-900 transition-all duration-300 flex flex-col">
            <div class="flex gap-0.5 mb-5">
              {Array.from({ length: t.rating }).map(() => (
                <svg
                  class="w-4 h-4 text-blue-400"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="text-slate-300 text-sm leading-relaxed flex-1 mb-6 italic">
              "{t.quote}"
            </blockquote>

            <div class="flex items-center gap-3 pt-5 border-t border-slate-800">
              <div
                class={`w-10 h-10 rounded-full ${t.color} flex items-center justify-center text-slate-950 font-bold text-sm shrink-0`}
              >
                {t.initial}
              </div>
              <div>
                <p class="text-white font-semibold text-sm">{t.name}</p>
                <p class="text-slate-500 text-xs">{t.role}</p>
                <p class="text-slate-600 text-xs mt-0.5">{t.conjunto}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
