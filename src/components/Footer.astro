---
const footerLinks = {
  producto: [
    { label: "Características", href: "#caracteristicas" },
    { label: "¿Cómo funciona?", href: "#como-funciona" },
    { label: "Testimonios", href: "#testimonios" },
    { label: "Precios", href: "#contacto" },
  ],
  modulos: [
    { label: "Control de Parqueaderos", href: "#caracteristicas" },
    { label: "Reserva de Espacios", href: "#caracteristicas" },
    { label: "Gym & Piscina", href: "#caracteristicas" },
    { label: "Citofonía Digital", href: "#caracteristicas" },
  ],
  empresa: [
    { label: "Acerca de", href: "#" },
    { label: "Blog", href: "#" },
    { label: "Contacto", href: "#contacto" },
    { label: "Trabaja con nosotros", href: "#" },
  ],
};
---

<footer class="relative bg-slate-950 border-t border-slate-800/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main footer content -->
    <div class="py-14 grid grid-cols-2 lg:grid-cols-5 gap-10">
      <!-- Brand column -->
      <div class="col-span-2 lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4 group w-fit">
          <div
            class="w-9 h-9 bg-linear-to-br from-blue-400 to-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-400/20 group-hover:scale-110 transition-transform"
          >
            <svg
              class="w-5 h-5 text-slate-950"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"></path>
            </svg>
          </div>
          <span class="text-xl font-extrabold tracking-tight">
            <span class="text-white">Habita</span><span class="text-blue-400"
              >red</span
            >
          </span>
        </a>
        <p class="text-slate-500 text-sm leading-relaxed mb-6 max-w-xs">
          La plataforma unificada para digitalizar y simplificar la
          administración de conjuntos residenciales en Colombia.
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-3">
          <a
            href="#"
            aria-label="Instagram"
            class="w-9 h-9 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-lg flex items-center justify-center text-slate-400 hover:text-white transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path>
            </svg>
          </a>
          <a
            href="#"
            aria-label="LinkedIn"
            class="w-9 h-9 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-lg flex items-center justify-center text-slate-400 hover:text-white transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <a
            href="https://wa.me/573001234567"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="w-9 h-9 bg-slate-800 hover:bg-emerald-700 border border-slate-700 hover:border-emerald-600 rounded-lg flex items-center justify-center text-slate-400 hover:text-white transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
              ></path>
              <path
                d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.121 1.524 5.855L0 24l6.335-1.506A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.876 0-3.64-.494-5.163-1.358l-.371-.22-3.762.894.944-3.653-.242-.377A9.935 9.935 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links columns -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Producto</h4>
        <ul class="space-y-3">
          {
            footerLinks.producto.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-500 hover:text-slate-300 text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Módulos</h4>
        <ul class="space-y-3">
          {
            footerLinks.modulos.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-500 hover:text-slate-300 text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Empresa</h4>
        <ul class="space-y-3">
          {
            footerLinks.empresa.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-500 hover:text-slate-300 text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="py-6 border-t border-slate-800/50 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-slate-600 text-xs">
        © {new Date().getFullYear()} Habitared. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-5">
        <a
          href="#"
          class="text-slate-600 hover:text-slate-400 text-xs transition-colors"
          >Términos de uso</a
        >
        <a
          href="#"
          class="text-slate-600 hover:text-slate-400 text-xs transition-colors"
          >Política de privacidad</a
        >
        <a
          href="#"
          class="text-slate-600 hover:text-slate-400 text-xs transition-colors"
          >Cookies</a
        >
      </div>
    </div>
  </div>
</footer>
